#!/usr/bin/env sh

if [[ $1 == "start" ]]; then
  echo entering mouse mode
  hyprctl keyword cursor:inactive_timeout 0
  hyprctl keyword cursor:hide_on_key_press false
  window-mode cursor
elif [[ $1 == "stop" ]]; then
  echo exiting mouse mode
  hyprctl keyword cursor:inactive_timeout 3
  hyprctl keyword cursor:hide_on_key_press true
  window-mode exit cursor
elif [[ $1 == "point" ]]; then
  echo pointing
  hyprctl dispatch submap reset && wl-kbptr -o modes=floating && window-mode cursor
elif [[ $1 == "point-click" ]]; then
  echo pointing and clicking
  wl-kbptr -o modes=floating,click
fi
